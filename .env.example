# Port sur lequel le serveur API écoute
API_PORT=8000

# Chemin vers le modèle de classification (.h5)
MODEL_PATH=cutisia_heavy_elite.h5

# Token d'authentification Ngrok (laisser vide pour désactiver le tunnel)
NGROK_AUTHTOKEN=votre_token_ici

# Répertoire de stockage des données collectées
COLLECT_DIR=collected_data

# Configuration Hugging Face (si nécessaire)
HF_TOKEN=votre_token_hf_ici
